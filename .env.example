# =========================================================================
# 行事曆自動同步所需環境變數範本
# 實際值請設定在 Vercel → Project → Settings → Environment Variables
# 切勿把真正的私鑰填進這個範本檔，也切勿 commit 真正的金鑰到 GitHub！
# =========================================================================

# 服務帳戶所在的 GCP / Firebase 專案 ID
GOOGLE_PROJECT_ID=yunlin-digital-travel

# 服務帳戶 email（在 Google Cloud → IAM 與管理 → 服務帳戶 找得到）
GOOGLE_CLIENT_EMAIL=xxxxx@yunlin-digital-travel.iam.gserviceaccount.com

# 服務帳戶私鑰：把下載的 JSON 裡 "private_key" 整段（含 BEGIN/END）貼上，
# 換行請保留成 \n（Vercel 介面直接貼多行也可，貼 JSON 原值最保險）
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMII...\n-----END PRIVATE KEY-----\n"

# 數辦公用行事曆的「行事曆 ID」
# 在 Google 行事曆 → 該行事曆 → 設定 → 「整合行事曆」→「行事曆 ID」
OFFICE_CALENDAR_ID=xxxxxxxxxxxxx@group.calendar.google.com

# 【僅在使用網域委派(DWD)時才需要】要假扮的校內帳號 email。
# 用於 Workspace 禁止對外部共用行事曆的情況：服務帳戶會以此帳號身分寫行事曆。
# 此帳號必須對目標行事曆有「變更活動」以上的權限。留空則走一般共用模式。
GOOGLE_IMPERSONATE_SUBJECT=your-account@ydlo.ylc.edu.tw
